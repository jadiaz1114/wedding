# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# Host/port the API listens on. Keep HOST at 127.0.0.1 so the process is
# only reachable through the Nginx reverse proxy, never directly from
# the internet.
HOST=127.0.0.1
PORT=3000

# Where the SQLite database file lives.
DB_PATH=./data/wedding.db

# Long random secret used to protect the /api/admin/*.csv export routes.
# Generate one with: openssl rand -hex 32
ADMIN_TOKEN=

# Your site's public origin, e.g. https://joseandmichelle.com
# When set, POST requests whose Origin header doesn't match this value
# are rejected (defense-in-depth against cross-site form abuse).
# Leave blank while testing locally.
ALLOWED_ORIGIN=
